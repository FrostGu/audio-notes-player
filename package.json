{
  "name": "@winterfx/pt",
  "version": "1.0.6",
  "description": "CLI tool for audio transcription with AI summary",
  "repository": {
    "type": "git",
    "url": "https://github.com/winterfx/Podcast-Transcription"
  },
  "bin": {
    "pt": "./cli/bin/podcast-transcribe.js"
  },
  "files": [
    "cli/bin",
    "cli/dist"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "dev:hono": "tsx watch src/server/index.ts",
    "build:hono": "vite build && esbuild src/server/index.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --alias:@=./src --external:puppeteer --external:openai",
    "start:hono": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cli": "tsx cli/src/index.ts",
    "pt": "tsx cli/src/index.ts",
    "build:cli": "esbuild cli/src/index.ts --bundle --platform=node --target=node20 --outfile=cli/dist/index.js --alias:@=./src --external:puppeteer",
    "prepublishOnly": "npm run build:cli",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "chalk": "^4.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.2",
    "lucide-react": "^0.469.0",
    "next": "16.1.1",
    "openai": "^4.77.4",
    "ora": "^5.4.1",
    "p-limit": "^7.2.0",
    "puppeteer": "^24.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "zustand": "^5.0.13",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "esbuild": "^0.24.2",
    "eslint": "^9",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "vite": "^6.3.0",
    "@vitejs/plugin-react": "^4.4.0",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0"
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}
